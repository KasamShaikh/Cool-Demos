{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["backend.main:app", "--reload", "--port", "8000"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Agent: agentdev CLI",
      "type": "debugpy",
      "request": "launch",
      "module": "agentdev",
      "args": ["run"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "preLaunchTask": "agentdev-install"
    },
    {
      "name": "Agent: AI Toolkit Inspector",
      "type": "debugpy",
      "request": "launch",
      "module": "agentdev",
      "args": ["run", "--inspect"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "preLaunchTask": "agentdev-install"
    }
  ]
}
